WITH base AS (
    SELECT 
        DATE_TRUNC('month', order_purchase_timestamp) AS mes,
        CASE WHEN order_delivered_customer_date > order_estimated_delivery_date THEN 1 ELSE 0 END AS atraso
    FROM orders
    WHERE order_status = 'delivered'
)
SELECT 
    mes,
    COUNT(*) AS total_entregas,
    SUM(atraso) AS total_atrasos,
    ROUND(100.0 * SUM(atraso) / COUNT(*), 2) AS percentual_atraso
FROM base
GROUP BY mes
ORDER BY mes