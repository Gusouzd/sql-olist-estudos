-- Desafio 06 — Percentual de pedidos atrasados por mês
-- Técnica: CASE WHEN comparando datas + DATE_TRUNC para agrupar por mês + divisão agregada para percentual
-- Lógica: filtra só pedidos entregues (status = 'delivered') → marca atraso quando data real > prazo estimado
--         → agrupa por mês e calcula percentual de atrasos sobre total de entregas
-- Detalhe: multiplicar por 100.0 (não 100) garante divisão decimal e evita resultado truncado em inteiro
-- Dataset: Olist | PostgreSQL

WITH base AS (
    SELECT 
        DATE_TRUNC('month', order_purchase_timestamp) AS mes,
        CASE WHEN order_delivered_customer_date > order_estimated_delivery_date THEN 1 ELSE 0 END AS atraso
    FROM orders
    WHERE order_status = 'delivered'
)
SELECT 
    mes,
    COUNT(*) AS total_entregas,
    SUM(atraso) AS total_atrasos,
    ROUND(100.0 * SUM(atraso) / COUNT(*), 2) AS percentual_atraso
FROM base
GROUP BY mes
ORDER BY mes